{
  "expo": {
    "name": "Gym ERP Mobile",
    "slug": "gym-erp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gymerp",
    "userInterfaceStyle": "automatic",
    "extra": {
      "projectName": "Gym ERP Mobile"
    },
    "ios": {
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Send gym updates, chat replies, support updates, and receipt notifications.",
        "NSMicrophoneUsageDescription": "Record voice notes in gym chat conversations.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      },
      "bundleIdentifier": "com.gymerp.mobile",
      "icon": "./assets/expo.icon"
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.gymerp.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}

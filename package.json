{
  "name": "gym-erp-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "up": "docker compose up -d",
    "up:build": "docker compose up -d --build",
    "pull-up": "docker compose pull && docker compose up -d",
    "down": "docker compose stop",
    "down:rm": "docker compose down",
    "down:volumes": "docker compose down -v",
    "logs": "docker compose logs -f",
    "ps": "docker compose ps",
    "restart": "docker compose restart",
    "reset": "docker compose down -v && docker compose up -d --build",
    "seed": "docker compose exec backend python -m app.seed_demo_data",
    "seed:all": "docker compose exec backend python -m app.initial_data && docker compose exec backend python -m app.seed_phase3_4 && docker compose exec backend python -m app.seed_demo_data",
    "dev:web": "docker compose up -d --build db backend frontend",
    "build:web": "docker compose build frontend",
    "rebuild:frontend": "docker compose build frontend",
    "dev:mobile": "npm run start --workspace @gym-erp/mobile",
    "dev:mobile:client": "npm run start:dev-client --workspace @gym-erp/mobile",
    "ios:mobile": "npm run ios --workspace @gym-erp/mobile",
    "ios:mobile:build": "npm run ios:dev --workspace @gym-erp/mobile",
    "android:mobile": "npm run android --workspace @gym-erp/mobile",
    "android:mobile:build": "npm run android:dev --workspace @gym-erp/mobile",
    "prebuild:mobile": "npm run prebuild --workspace @gym-erp/mobile",
    "prebuild:mobile:clean": "npm run prebuild:clean --workspace @gym-erp/mobile",
    "typecheck:mobile": "npm run typecheck --workspace @gym-erp/mobile",
    "test:api": "./.venv/bin/python -m pytest tests/test_auth.py -q",
    "test:api:all": "./.venv/bin/python -m pytest -q",
    "typecheck:web": "npm run typecheck --workspace frontend",
    "lint:web": "npm run lint --workspace frontend",
    "test:web": "npm run test:e2e:fast --workspace frontend"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
